{
  "name": "snake-game",
  "version": "1.0.0",
  "description": "HTML5 Snake game with testing",
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:html": "html-validate index.html"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "eslint": "^8.57.0",
    "html-validate": "^8.18.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "*.js",
      "!jest.config.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  }
}
